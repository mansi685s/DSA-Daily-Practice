/*
Problem- 413.Arthmetic Slices
Platform- Leetcode
Difficulty- Medium
Frequency -0ms
Approach-Iterative Method
Starting with index 2 so nums[i]-nums[i-1]==nums[i-1]-nums[i-2] sol slice is present with atleast three element.
if not then current elemnt is again 0 .
Solution-*/
class Solution {
    public int numberOfArithmeticSlices(int[] nums) {
        if(nums.length<3){
            return 0;
        }
        int res=0,curr=0;
        for(int i=2;nums.length>i;i++){
            if(nums[i]-nums[i-1]==nums[i-1]-nums[i-2]){
                curr++; res+=curr;
            }
            else{
                curr=0;
            }
        }
        return res;
    }
}
