Problem-1208. Get Equal Substrings Within Budget
Platform-Leetcode
Frequency-8ms
Difficulty-medium
Approach-Sliding window
Solution-
class Solution {
    public int equalSubstring(String s, String t, int maxCost) {
     int left=0,lencost=0,max=0;
     for(int i=0;s.length()>i;i++){
        max+=Math.abs(s.charAt(i)-t.charAt(i));
       while(max>maxCost){
        max-=Math.abs(s.charAt(left)-t.charAt(left));
        left++;
       }
      lencost=Math.max(lencost,i-left+1);
     }   
     return lencost;
    }
}
