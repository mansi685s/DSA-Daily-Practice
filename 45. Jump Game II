/*
Problem- 45. Jump Game II
Platform- Leetcode
Frequency- 2ms
Difficulty- Medium
Approach- Dynamic Programming
Solution- */
class Solution {
    public int jump(int[] nums) {
        int jump=0;
        int maxj=0,total=0;;
        for(int i=0;nums.length-1>i;i++){
              maxj=Math.max(maxj,nums[i]+i);
              if(maxj>=nums.length-1){
                ++jump;
                break;
              }
             if(i==total){
                ++jump;
                total=maxj;
             }
        }
        return jump;
    }
}
