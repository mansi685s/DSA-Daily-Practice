Problem-1493. Longest Subarray of 1's After Deleting One Element
Platform-Leetcode
Frequency-3ms
Difficulty-Medium
Approach-Sliding Window
Solution-
class Solution {
    public int longestSubarray(int[] nums) {
     int left=0,zer=0,max=0;
     for(int i=0;nums.length>i;i++){
        if(nums[i]==0)zer++;
        while(zer>1){
            if(nums[left]==0)zer--;
            left++;
        }
        max=Math.max(max,i-left);
     }
     return max;
    }
}
