/*Problem-71. Simplify Path
Platform- Leetcode
Difficulty-Medium
Frequency-5ms
Approach-Stack,String Builder
Solution-*/
class Solution {
    public String simplifyPath(String path) {
        Stack<String>stack=new Stack<>();
        String p1[]=path.split("/");
        for(String ch:p1){
            if(ch.equals("")||ch.equals(".")){
                continue;
            }
            if(ch.equals("..")){
                if(!stack.isEmpty()){
                    stack.pop();
                }
            }else{
                stack.push(ch);
            }
        }
         StringBuilder sb = new StringBuilder();
        while (!stack.isEmpty()) {
            sb.insert(0, "/" + stack.pop());
        }
          if (sb.length() == 0) {
          return "/";
          }else {
        return sb.toString();
}
    }
}
