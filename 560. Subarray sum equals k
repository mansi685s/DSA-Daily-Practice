/*Problem-560. Subarray sum equals k
Platform-Leetcode
Frequency-1555ms
Difficulty-Medium
Solution-*/
class Solution {
    public int subarraySum(int[] nums, int k) {
int count=0;
        for(int i=0;nums.length>i;i++){
            int sum=0;
            for(int j=i;nums.length>j;j++){
                sum+=nums[j];
                if(sum==k){
                    count++;
                }
            }
        }
        return count;
    }
}
