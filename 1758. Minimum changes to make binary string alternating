/*
Problem- 1758. Minimum changes to make binary string alternating
Platform- Leetcode
Difficulty- Easy
Frequency- 2ms
Approach- Define Two Target Patterns:
Pattern 1: Starts with '0' → positions 0,2,4... should be '0', positions 1,3,5... should be '1'
Pattern 2: Starts with '1' → positions 0,2,4... should be '1', positions 1,3,5... should be '0'
Solutions-*/
class Solution {
    public int option(String s,char ch){
        int i=0,count=0;
        while(s.length()>i){
            if(i%2==0&&s.charAt(i)!=ch){
                  count++;
            }
            else if(i%2==1&&s.charAt(i)==ch){
               count++;
            }
            i++;
        }
        return count;
    }
    public int minOperations(String s) {
       int a=option(s,'0');
       int b=option(s,'1');
       return Math.min(a,b);
    }
}
