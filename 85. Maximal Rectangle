Problem-85. Maximal Rectangle
Platform-Leetcode
Frequency-24ms
Difficulty-Hard
Approach-Stack
Solution-
class Solution {
    public int maximalRectangle(char[][] matrix) {
        int mat[][]=new int[matrix.length][matrix[0].length];
        for(int i=0;matrix.length>i;i++){
            for(int j=0;matrix[i].length>j;j++){
                mat[i][j]=matrix[i][j]-'0';
            }
        }
        int m[]=new int[mat[0].length];
        int max=0;
        for(int i=0;mat.length>i;i++){
           for(int j=0;j<matrix[0].length; j++){
                if(matrix[i][j] == '1')
                    m[j] += 1;
                else
                    m[j] = 0;
            }
        
        Stack<Integer>s1=new Stack<>();
        s1.push(-1);
      
        for(int j=0;m.length>j;j++){
          while(s1.peek()!=-1 && m[j]<=m[s1.peek()]){
            int height=m[s1.pop()];
            int width=j-s1.peek()-1;
            max=Math.max(max,height*width);
          }
          s1.push(j);
        }
        
        while(s1.peek()!=-1 ){
            int height=m[s1.pop()];
            int width=m.length-s1.peek()-1;
            max=Math.max(max,height*width);
          }
        }
          return max;
    }
}
