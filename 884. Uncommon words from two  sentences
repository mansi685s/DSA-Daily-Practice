/*Problem-884. Uncommon words from two  sentences
Platform-Leetcode
Difficulty-easy
Frequency-5ms
Approach-HASHMAP
Solution-*/
class Solution {
    public String[] uncommonFromSentences(String s1, String s2) {
        HashMap<String,Integer>map=new HashMap<>();
        String a="";
        ArrayList<String>list=new ArrayList<>();
        for(int i=0;s1.length()>i;i++){
            char ch=s1.charAt(i);
            if(ch==' '){
                map.put(a,map.getOrDefault(a,0)+1);
                a="";
            }
            else{
                a+=ch;
            }
        }
        map.put(a,map.getOrDefault(a,0)+1);
                a="";
        for(int i=0;s2.length()>i;i++){
            char ch=s2.charAt(i);
            if(ch==' '){
                map.put(a,map.getOrDefault(a,0)+1);
                a="";
            }
            else{
                a+=ch;
            }
        }
         map.put(a,map.getOrDefault(a,0)+1);
        for(String key: map.keySet()){
            if(map.get(key)==1){
                list.add(key);
            }
        }    
        String arr[]=new String[list.size()];
        int i=0;
        for(String x:list){
            arr[i]=x;
            i++;
        }
        return arr;
    }
}
