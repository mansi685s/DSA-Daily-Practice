/*Problem-3868. Minimum Cost to Equalize Arrays Using Swaps 
Platform-Leetcode
Difficulty-medium, Weekly Digest
Frequency-112ms
Approach-HashMap
Solution-*/
class Solution {
    public int minCost(int[] nums1, int[] nums2) {
        HashMap<Integer,Integer>m1=new HashMap<>();
        if(Arrays.equals(nums1,nums2)){
            return 0;
        }
        for(int x:nums1){
            m1.put(x,m1.getOrDefault(x,0)+1);
        }
        int cost=0;
        for(int x:nums2){
            m1.put(x,m1.getOrDefault(x,0)-1);
        }
        ArrayList<Integer>list=new ArrayList<>();
        for(int x:m1.keySet()){
            int a=m1.get(x);
            if(a%2!=0)return -1;
            for(int i=0;Math.abs(a)/2>i;i++){
                list.add(x);
            }
        }
            if(list.size()==0)return 0;
        Collections.sort(list);
        int min=Integer.MAX_VALUE;
        for(int x:nums1){
           min= Math.min(x,min);
        }
        for(int x:nums2){
           min= Math.min(x,min);
        }
        for(int i=0;list.size()/2>i;i++){
            cost++;
        }
        return cost;
    }
}
