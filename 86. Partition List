/*Problem-86. Partition List
Difficulty- Medium
Platform- Leetcode
Frequency-0ms
Approach- LinkedList

Create two dummy lists:
one for nodes smaller than x and one for nodes greater or equal to x.
Traverse the original linked list once.
If node value is less than x, attach it to small list.
Otherwise attach it to greater list.
After traversal, connect small list with greater list.
Make last node of greater list point to null to avoid cycle.
Return head of the small list.

Solution-*/
class Solution {
    public ListNode partition(ListNode head, int x) {
        ListNode small = new ListNode(0);
        ListNode greater = new ListNode(0);

        ListNode sma = small;
        ListNode grea = greater;

        while(head != null){
            if(head.val < x){
                sma.next = head;
                sma = sma.next;
            }
            else{
                grea.next = head;
                grea = grea.next;
            }
            head = head.next;
        }

        grea.next = null;
        sma.next = greater.next;

        return small.next;
    }
}
