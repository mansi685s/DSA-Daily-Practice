/*Problem-3184. Count pairs that form a complete day I
Platform-Leetcode
Difficulty-easy
Frequency-1ms
Approach-Two Pointer
Solution-*/
class Solution {
    public int countCompleteDayPairs(int[] hours) {
        int count=0;
        int i=0,j=i+1;
        while(i<hours.length-1){
            if(j==hours.length){
                i++;j=i+1;
                continue;
            }
            if((hours[i]+hours[j])%24==0){
                count++;
            }
            j++;
        }
        return count;
    }
}
