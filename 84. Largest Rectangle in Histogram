Problem-84. Largest Rectangle in Histogram
Difficulty-Hard
Frequency-69
Approach-Stack
Solution-
class Solution {
    public int largestRectangleArea(int[] height) {
        int max=0;
        Stack<Integer>stack=new Stack<>();

        if(height.length==1)return height[0];

        stack.push(-1);  

        for(int i=0;height.length>i;i++){
           while(stack.peek()!=-1 && height[i]<=height[stack.peek()]){
            int sum=height[stack.pop()];
            int count=i-stack.peek()-1;
            max=Math.max(max,sum*count);
           }
           stack.push(i);
        }
        while(stack.peek()!=-1){
            int sum=height[stack.pop()];
            int count=height.length-stack.peek()-1;
            max=Math.max(max,sum*count);
           }
        return max;
    }
}
