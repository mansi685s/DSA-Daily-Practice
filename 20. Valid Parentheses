/*Problem- 20.Valid Parentheses
Platform- Leetcode
Frequency- 3ms
Difficulty-easy
Approach-stack
Solution-*/
class Solution {
    public boolean isValid(String s) {
     Stack<Character> stack = new Stack<>();
        for(char c : s.toCharArray()) {
            if(c == '(' || c == '{' || c == '[') {
                stack.push(c);
            } 
            else {
                if(stack.isEmpty()) return false;
                char top = stack.pop();
                if(c == ')' && top != '(') return false;
                if(c == '}' && top != '{') return false;
                if(c == ']' && top != '[') return false;
            }
        }
        return stack.isEmpty();
    }
}
