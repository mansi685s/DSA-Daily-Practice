/*
Problem-143. Reorder List
Platform-Leetcode
Difficulty-Medium
Frequency-2ms
Approach-LinkedList, TwoPointer
Solution-
*/
class Solution {
    public void reorderList(ListNode head) {
        ListNode slow = head, fast = head;
        while(fast.next != null && fast.next.next != null) {
            slow = slow.next;
            fast = fast.next.next;
        }
        ListNode prev=null,currnext=null,curr=slow.next;
        while(curr!=null){
            currnext=curr.next;
            curr.next=prev;
            prev=curr;
            curr=currnext;
        }
        slow.next=null;
       ListNode first=head;
      ListNode second=prev;
      while(second!=null){
        ListNode temp1=first.next;
        ListNode temp2=second.next;
        first.next=second;
        second.next=temp1;
         first = temp1;
            second = temp2;
      }
        
    }
}
