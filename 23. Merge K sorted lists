/*Problem- Merge K Sorted Lists
Difficulty- Hard
Platform- Leetcode
Frequency-64ms
Approach- LinkedList, Iterative Merging

Create a helper function to merge two sorted linked lists.
Use a dummy node to build merged list.
Compare nodes of both lists and attach smaller value node.
Move pointer forward after every insertion.
Attach remaining nodes if any list is not empty.
Traverse the array of lists and keep merging one by one.
Return final merged linked list.

Solution-*/
class Solution {

    public ListNode merge(ListNode h1, ListNode h2){
        ListNode res = new ListNode(-1);
        ListNode tail1 = res;

        while(h1 != null && h2 != null){
            if(h1.val >= h2.val){
                tail1.next = new ListNode(h2.val);
                h2 = h2.next;
            }
            else{
                tail1.next = new ListNode(h1.val);
                h1 = h1.next;
            }
            tail1 = tail1.next;
        }

        if(h1 != null){
            tail1.next = h1;
        }

        if(h2 != null){
            tail1.next = h2;
        }

        return res.next;
    }

    public ListNode mergeKLists(ListNode[] lists) {
        if (lists == null || lists.length == 0) return null;

        ListNode tail = null;

        for(int i = 0; i < lists.length; i++){
            tail = merge(tail, lists[i]);
        }

        return tail;
    }
}
