/*
Problem- 914. X of a kind in a Deck of cards
Platform- Leetcode
Difficulty-easy
Frequency-11ms
Approach-HashMap
Solution-*/
class Solution {
    public boolean hasGroupsSizeX(int[] deck) {
        HashMap<Integer,Integer>map=new HashMap<>();
        int a=Integer.MAX_VALUE;;
        for(int x:deck){
            map.put(x,map.getOrDefault(x,0)+1);
        }
        
        for(int key:map.keySet()){
            a=Math.min(a,map.get(key));
        }
        if(a<=1)return false;
       for(int size=2;size<=a;size++){
            boolean abc=true;
            for(int key:map.keySet()){
                if(map.get(key)%size!=0){
                    abc=false;
                    break;
                }
            }
            if(abc)return true;
        }
        return false;
    }
}
