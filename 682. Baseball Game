/*Problem- 682.Baseball game
Difficulty- Easy
Platform- Leetcode
Frequency- 3ms
Approaach- stack
Solution-*/
class Solution {
    public int calPoints(String[] operations) {
        Stack<Integer>stack=new Stack<>();
        for(int i=0;operations.length>i;i++){
           char ch = operations[i].charAt(0);
            if(ch >= '0' && ch <= '9' || ch == '-'){ 
                stack.push(Integer.parseInt(operations[i]));
            }
            else if(ch=='C'){
                stack.pop();
            }
            else if(ch=='D'){
              stack.push(stack.peek()*2);
            }
            else{
                int top=stack.pop();
                int nt=top+stack.peek();
                stack.push(top);
                stack.push(nt);
            }
        }
        int sum=0;
        for(int x:stack){
            sum+=x;
                    }
    
    return sum;
}}
