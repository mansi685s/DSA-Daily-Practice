/*Problem- 32. Longest valid parentheses
Platform-Leetcode
Difficulty- Hard
Frequency-5ms

Approach-Stack,dynamic programming
Create a stack to store indices.
Push -1 as a base reference.
Traverse the string:
If current character is '(', push its index.
If current character is ')':
Pop the top element.
If stack becomes empty:
Push current index (new base).
Else:
Calculate valid length as:
i - st.peek()
Update maximum length.

Solution-*/
class Solution {
    public int longestValidParentheses(String s) {
         Stack<Integer> stack = new Stack<>();
        stack.push(-1);
        int max_len = 0;

        for (int i = 0; i < s.length(); i++) {
            if (s.charAt(i) == '(') {
                stack.push(i);
            } else {
                stack.pop();
                if (stack.isEmpty()) {
                    stack.push(i);
                } else {
                    max_len = Math.max(max_len, i - stack.peek());
                }
            }
        }

        return max_len;  
    }
}
