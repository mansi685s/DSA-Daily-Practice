/*
Problem-1370.Increasing decreasing string
Platform-Leetcode
Difficulty-easy
Frequency-3ms
Approach-iterative method
Saved all character frequency of string in array of size 26.
created a string builder .
Array is iterated till the length of stringbuilder is less then string length.
Appended each letter of string in ascending order and reduce frequency by 1 if geater then 0.
Then append all char in descending.
Repeat process till all char is appended in stringbuilder.
Solution-*/
class Solution {
    public String sortString(String s) {
        int arr[]=new int[26];
        for(char a:s.toCharArray()){
            arr[a-'a']++;
        }
        StringBuilder a=new StringBuilder();
        while(a.length()<s.length()){
            for(int i=0;26>i;i++){
                if(arr[i]!=0){
                    arr[i]--;
                    a.append((char)(i+'a'));
                }
            }
            for(int i=25;0<=i;i--){
                if(arr[i]!=0){
                    arr[i]--;
                    a.append((char)(i+'a'));
                }
            }
        }
        return a.toString();
    }
}
